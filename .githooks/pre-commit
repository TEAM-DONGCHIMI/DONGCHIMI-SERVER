#!/bin/sh

# 1. 스테이징된 Kotlin 파일만 추출 (삭제된 파일 d 는 제외)
STAGED_FILES="$(git --no-pager diff --name-only --no-color --cached --diff-filter=d | grep -E '\.kts?$')"

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "[ktlint] 다음 파일을 포맷합니다:"
echo "$STAGED_FILES"

# 2. 스테이징 안 된 변경사항을 잠시 백업 후 워킹트리에서 제거
#    (git add -p 로 부분만 스테이징한 경우, 안 올린 변경까지 add 되는 걸 방지)
UNSTAGED_DIFF="$(git rev-parse --git-dir)/pre-commit-unstaged.diff"
git diff --color=never > "$UNSTAGED_DIFF"
if [ -s "$UNSTAGED_DIFF" ]; then
  git apply -R "$UNSTAGED_DIFF"
fi

# 3. 스테이징된 파일만 포맷
./gradlew --quiet ktlintFormat -PinternalKtlintGitFilter="$STAGED_FILES"
GRADLE_EXIT=$?

# 4. 포맷된 파일만 다시 add (git add -A 아님)
echo "$STAGED_FILES" | while IFS= read -r file; do
  [ -f "$file" ] && git add "$file"
done

# 5. 백업했던 스테이징 안 된 변경사항 복원
if [ -s "$UNSTAGED_DIFF" ]; then
  git apply --ignore-whitespace "$UNSTAGED_DIFF"
fi
rm -f "$UNSTAGED_DIFF"

# 6. 자동 수정 불가한 lint 에러가 있으면 커밋 중단
if [ "$GRADLE_EXIT" -ne 0 ]; then
  echo "[ktlint] 자동 수정으로 해결되지 않는 문제가 있습니다. 커밋을 중단합니다."
fi

exit $GRADLE_EXIT