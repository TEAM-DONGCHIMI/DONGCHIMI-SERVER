# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ISSUER=dongchimi
JWT_ACCESS_TOKEN_EXPIRY=3600000
JWT_REFRESH_TOKEN_EXPIRY=1209600000

# Refresh Token Cookie
REFRESH_COOKIE_SECURE=true

# Admin Signup
ADMIN_SIGNUP_VERIFICATION_CODE=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

#DB
# prod: RDS 엔드포인트 (jdbc:postgresql://<rds-endpoint>:5432/dongchimidb)
# dev: 같은 RDS 인스턴스의 dev 전용 database (jdbc:postgresql://<rds-endpoint>:5432/dongchimi_dev)
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# Redis
# prod: docker-compose 내부 서비스명(redis), local: docker/local/docker-compose.yml로 기동
REDIS_HOST=localhost
REDIS_PORT=6379

# 계정 존재 캐시 TTL (USER/OWNER)
ACCOUNT_CACHE_TTL=PT10M

# Deploy (docker/dev, docker/prod)
# dev: DOMAIN=dev-api.example.com, IMAGE_TAG=dev (main push마다 deploy-dev.yml이 갱신)
# prod: DOMAIN=api.example.com, IMAGE_TAG=latest (GitHub Release published 시 deploy-prod.yml이 갱신)
DOMAIN=api.example.com
ACME_EMAIL=admin@example.com
IMAGE_REPO=your-dockerhub-user
IMAGE_TAG=latest

# OAuth
KAKAO_USER_INFO_URI=https://kapi.kakao.com/v2/user/me
KAKAO_TOKEN_URI=https://kauth.kakao.com/oauth/token
KAKAO_CLIENT_ID=your-kakao-rest-api-key-here
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://your-app.com/oauth/callback
KAKAO_CONNECT_TIMEOUT=2s
KAKAO_READ_TIMEOUT=5s

# Storage (S3)
STORAGE_PROVIDER=s3
STORAGE_PRESIGN_EXPIRY=PT5M
CDN_BASE_URL=https://cdn.example.com
AWS_REGION=ap-northeast-2
S3_BUCKET=your-bucket-name

# 로컬 개발(LocalStack) 시에만 사용
S3_ENDPOINT=
S3_PATH_STYLE=false

# 로컬에서 DefaultCredentialsProvider가 사용하는 자격증명 (prod는 IAM Role 사용, 값 비움)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 전단 QR (infrastructure:qr)
FLYER_BASE_URL=https://app.dongchiimi.com
QR_SIZE=183
QR_MARGIN=1

# Monitoring - Discord
DISCORD_ALERT_ENABLED=false
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_CONNECT_TIMEOUT=2s
DISCORD_READ_TIMEOUT=3s

# Monitoring - Sentry
SENTRY_ENABLED=false
SENTRY_DSN=https://xxxx@oyyyy.ingest.sentry.io/zzzz
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.0

# 상품 등록 엑셀 분석 - AI (카테고리 분류·이미지 매칭). mock 또는 gemini
IMPORT_AI_PROVIDER=mock
IMPORT_MOCK_LATENCY=PT0.3S

# 상품 등록 엑셀 분석 - Gemini (공식 GenAI SDK, Vertex AI 인증)
# 인증은 API key가 아니라 ADC로 한다. 아래 GOOGLE_APPLICATION_CREDENTIALS에 서비스 계정 JSON 키 경로를 준다.
# (AWS 등 GCP 밖에서 실행 시 필수. 키 파일을 컨테이너에 마운트하고 이 경로로 가리킬 것)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GEMINI_PROJECT=your-gcp-project-id
GEMINI_LOCATION=global
GEMINI_MODEL=gemini-3.1-flash-lite
# 3.x 사고 깊이: minimal | low | medium | high. 미지정 시 모델 기본이 high(가장 느림)
GEMINI_THINKING_LEVEL=low
GEMINI_TIMEOUT=60s

# 상품 등록 엑셀 분석 - 작업 큐 워커
IMPORT_JOB_LEASE=PT5M
IMPORT_JOB_POLL_INTERVAL=PT1S
IMPORT_JOB_SLOTS_PER_INSTANCE=4
IMPORT_JOB_MAX_ATTEMPTS=5
IMPORT_JOB_AI_CONCURRENCY=10
IMPORT_JOB_AI_BATCH_SIZE=50

# 상품·마트 조회수 Redis 캐싱 → DB 동기화
VIEW_COUNT_DEDUP_TTL=PT24H
VIEW_COUNT_FLUSH_INTERVAL=PT10S

# 공휴일 API (한국천문연구원 특일정보, data.go.kr)
# 인증키는 포털의 "Decoding" 키를 넣는다 (Encoding 키를 넣으면 이중 인코딩으로 인증 실패)
HOLIDAY_API_SERVICE_KEY=
HOLIDAY_API_CONNECT_TIMEOUT=2s
HOLIDAY_API_READ_TIMEOUT=3s

# 공휴일 Redis 캐시 (임시공휴일 반영 위해 TTL 1일, 장애 시 빈 값 짧은 TTL)
HOLIDAY_CACHE_TTL=P1D
HOLIDAY_CACHE_FALLBACK_TTL=PT10M
