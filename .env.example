# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ISSUER=dongchimi
JWT_ACCESS_TOKEN_EXPIRY=3600000
JWT_REFRESH_TOKEN_EXPIRY=1209600000

# Refresh Token Cookie
REFRESH_COOKIE_SECURE=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

#DB
# prod: RDS 엔드포인트 (jdbc:postgresql://<rds-endpoint>:5432/dongchimidb)
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# Redis
# prod: docker-compose 내부 서비스명(redis), local: docker/local/docker-compose.yml로 기동
REDIS_HOST=localhost
REDIS_PORT=6379

# Deploy (docker/prod)
DOMAIN=api.example.com
ACME_EMAIL=admin@example.com
IMAGE_REPO=your-dockerhub-user
IMAGE_TAG=latest

# OAuth
KAKAO_USER_INFO_URI=https://kapi.kakao.com/v2/user/me
KAKAO_TOKEN_URI=https://kauth.kakao.com/oauth/token
KAKAO_CLIENT_ID=your-kakao-rest-api-key-here
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://your-app.com/oauth/callback
KAKAO_CONNECT_TIMEOUT=2s
KAKAO_READ_TIMEOUT=5s

# Storage (S3)
STORAGE_PROVIDER=s3
STORAGE_PRESIGN_EXPIRY=PT5M
CDN_BASE_URL=https://cdn.example.com
AWS_REGION=ap-northeast-2
S3_BUCKET=your-bucket-name

# 로컬 개발(LocalStack) 시에만 사용
S3_ENDPOINT=
S3_PATH_STYLE=false

# 로컬에서 DefaultCredentialsProvider가 사용하는 자격증명 (prod는 IAM Role 사용, 값 비움)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 전단 QR (infrastructure:qr)
FLYER_BASE_URL=https://app.dongchiimi.com
QR_SIZE=183
QR_MARGIN=1

# Monitoring - Discord
DISCORD_ALERT_ENABLED=false
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_CONNECT_TIMEOUT=2s
DISCORD_READ_TIMEOUT=3s

# Monitoring - Sentry
SENTRY_ENABLED=false
SENTRY_DSN=https://xxxx@oyyyy.ingest.sentry.io/zzzz
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.0

# 상품 등록 엑셀 분석 - AI (카테고리 분류·이미지 매칭). mock 또는 gemini
IMPORT_AI_PROVIDER=mock
IMPORT_MOCK_LATENCY=PT0.3S

# 상품 등록 엑셀 분석 - Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_CONNECT_TIMEOUT=3s
GEMINI_READ_TIMEOUT=20s
GEMINI_MAX_RETRIES=2

# 상품 등록 엑셀 분석 - 작업 큐 워커
IMPORT_JOB_LEASE=PT5M
IMPORT_JOB_POLL_INTERVAL=PT1S
IMPORT_JOB_SLOTS_PER_INSTANCE=4
IMPORT_JOB_MAX_ATTEMPTS=5
IMPORT_JOB_AI_CONCURRENCY=10
IMPORT_JOB_AI_BATCH_SIZE=50
