# 복사해서 k6/.env.perf 로 사용한다 (.env.perf는 git에 커밋하지 않음).

# 부하 대상(SUT) URL.
BASE_URL=http://host.docker.internal:8080

# smoke | load | stress | spike | importLatency | importThroughput (k6/config/options.js 참고)
# 엑셀 분석 벤치마크는 importLatency(순차 1 VU) 또는 importThroughput(동시 N VU)를 쓴다.
PROFILE=importLatency

# --- 상품 등록 엑셀 분석 벤치마크 (product-import-sync.js / product-import-async.js) ---

# 분석 대상 마트 ID 풀. 쉼표로 나열하면 VU 마다 다른 마트에 배정된다(동시 실행 시 경합 회피).
# ⚠ 분석은 대상 마트의 prepared_products 를 통째로 덮어쓰므로 버릴 수 있는 테스트 마트만 넣는다.
# k6/data/seed-benchmark-markets.sql 로 owner_id=1 마트 9001~9100 을 시딩한 뒤,
# 동시 VU 수만큼 골라 넣는다 (importLatency 는 1개면 충분, importThroughput 은 IMPORT_VUS 개 이상).
IMPORT_MARKET_IDS=9001

# S3 에 미리 업로드한 분석용 엑셀 파일 URL (우리 버킷 도메인이어야 함 — SSRF 가드).
IMPORT_EXCEL_FILE_URL=https://cdn.dongchimi.kr/products/imports/2026/07/sample.xlsx

# per-VU 표본 수와 동시 VU 수 (importLatency/importThroughput 프로파일에서 사용).
IMPORT_ITERATIONS=5
IMPORT_VUS=5

# 한 번의 분석 최대 대기 시간(기본 120s).
IMPORT_TIMEOUT=120s

# --- 인증 (둘 중 하나) ---
# 1) 발급된 OWNER access token 을 직접 넣거나,
OWNER_ACCESS_TOKEN=
# 2) 비워두면 local-token 으로 발급한다 (local 프로파일 서버 전용). 이 userId 가 마트 소유자여야 한다.
OWNER_USER_ID=1
